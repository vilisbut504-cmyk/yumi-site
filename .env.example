# Режим деплоя: timeweb (SSR, по умолчанию) | github-pages (static export)
DEPLOY_TARGET=

# CRM: demo — заявки логируются на сервере; server — отправка в amoCRM
NEXT_PUBLIC_CRM_MODE=demo

# Публичный URL сайта (для metadata, sitemap)
NEXT_PUBLIC_SITE_URL=

# amoCRM (только сервер, не NEXT_PUBLIC_)
AMO_BASE_DOMAIN=
AMO_ACCESS_TOKEN=
AMO_PIPELINE_ID=
AMO_STATUS_NEW_ID=
AMO_RESPONSIBLE_USER_ID=

# Базовый URL хранилища фото товаров (Timeweb Cloud S3).
# Если не задан — используется /fallback-product.webp
NEXT_PUBLIC_ASSETS_BASE_URL=

# Timeweb App Platform
HOST=0.0.0.0
PORT=3000
